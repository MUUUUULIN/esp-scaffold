{% raw %}#include "pwm_driver.h"

static const char *TAG = "pwm";

#define LEDC_TIMER          LEDC_TIMER_0
#define LEDC_MODE           LEDC_LOW_SPEED_MODE
#define LEDC_FREQ_HZ        5000
#define LEDC_DUTY_RES       LEDC_TIMER_10_BIT
#define LEDC_CHANNEL_0      LEDC_CHANNEL_0
#define LEDC_OUTPUT_IO_0    (-1)  /* TODO: set your PWM output pin */

void pwm_driver_init(void)
{
    ESP_LOGI(TAG, "Initializing PWM (LEDC Timer 0, %d Hz)...", LEDC_FREQ_HZ);

    ledc_timer_config_t timer_cfg = {
        .speed_mode = LEDC_MODE,
        .timer_num  = LEDC_TIMER,
        .duty_resolution = LEDC_DUTY_RES,
        .freq_hz    = LEDC_FREQ_HZ,
        .clk_cfg    = LEDC_AUTO_CLK,
    };
    ESP_ERROR_CHECK(ledc_timer_config(&timer_cfg));

    ledc_channel_config_t ch_cfg = {
        .speed_mode = LEDC_MODE,
        .channel    = LEDC_CHANNEL_0,
        .timer_sel  = LEDC_TIMER,
        .intr_type  = LEDC_INTR_DISABLE,
        .gpio_num   = LEDC_OUTPUT_IO_0,
        .duty       = 0,
        .hpoint     = 0,
    };
    ESP_ERROR_CHECK(ledc_channel_config(&ch_cfg));

    ESP_LOGI(TAG, "PWM initialized successfully");
}{% endraw %}
