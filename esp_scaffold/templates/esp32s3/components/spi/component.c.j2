{% raw %}#include "spi_driver.h"

static const char *TAG = "spi";

spi_device_handle_t spi_dev;

void spi_driver_init(void)
{
    ESP_LOGI(TAG, "Initializing SPI (SPI2_HOST)...");

    spi_bus_config_t bus_cfg = {
        .mosi_io_num = -1,   /* TODO: set your MOSI pin */
        .miso_io_num = -1,   /* TODO: set your MISO pin */
        .sclk_io_num = -1,   /* TODO: set your SCLK pin */
        .quadwp_io_num = -1,
        .quadhd_io_num = -1,
        .max_transfer_sz = 4092,
    };

    ESP_ERROR_CHECK(spi_bus_initialize(SPI2_HOST, &bus_cfg, SPI_DMA_CH_AUTO));

    spi_device_interface_config_t dev_cfg = {
        .mode = 0,
        .clock_speed_hz = 10 * 1000 * 1000,  /* 10 MHz */
        .spics_io_num = -1,                   /* TODO: set your CS pin */
        .queue_size = 7,
    };

    ESP_ERROR_CHECK(spi_bus_add_device(SPI2_HOST, &dev_cfg, &spi_dev));

    ESP_LOGI(TAG, "SPI initialized successfully");
}{% endraw %}
